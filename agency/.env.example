# ── Agency Identity ───────────────────────────────────────────────────────────
AGENCY_NAME=AutoFlow AI Agency
OWNER_NAME=Alex
OWNER_EMAIL=you@yourdomain.com
AGENCY_WEBSITE=https://yoursite.com

# ── AI (Required) ─────────────────────────────────────────────────────────────
# Get at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Lead Discovery (Optional — uses mock data if blank) ───────────────────────
# Get at https://console.cloud.google.com → Maps → Places API
GOOGLE_PLACES_API_KEY=AIza...

# ── Email Outreach (Optional — logs-only if blank) ────────────────────────────
# Gmail: enable 2FA → generate App Password at myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password

# ── Email Finding (Optional) ──────────────────────────────────────────────────
# https://hunter.io — free 25 searches/month
HUNTER_API_KEY=

# ── Payments (Optional) ───────────────────────────────────────────────────────
# https://stripe.com — hook webhook to /webhook endpoint
STRIPE_SECRET_KEY=sk_live_...

# ── Targets ───────────────────────────────────────────────────────────────────
WEEKLY_REVENUE_TARGET=1000
OUTREACH_DAILY_LIMIT=15
LEADS_PER_RUN=20
