# ── Agency Identity ───────────────────────────────────────────────────────────
AGENCY_NAME=AutoFlow AI Agency
OWNER_NAME=Alex
OWNER_EMAIL=you@yourdomain.com
AGENCY_WEBSITE=https://yoursite.com

# ── AI — FREE (Required for personalized copy) ────────────────────────────────
# Sign up at https://groq.com — no credit card, 2 min, 14,400 free requests/day
GROQ_API_KEY=gsk_...

# ── Legacy AI (No longer needed — Groq replaces this for free) ────────────────
# ANTHROPIC_API_KEY=sk-ant-...

# ── Lead Discovery (No longer needed — Yelp scraping is free) ────────────────
# GOOGLE_PLACES_API_KEY=AIza...

# ── Email Outreach (Optional — logs-only mode if blank) ───────────────────────
# Gmail: enable 2FA → generate App Password at myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password

# Where to receive internal alerts (optional)
NOTIFY_EMAIL=

# ── Email Finding (No longer needed — built-in website scraper is free) ───────
# HUNTER_API_KEY=

# ── Payments (Optional) ───────────────────────────────────────────────────────
# https://stripe.com — hook webhook to /webhook endpoint
STRIPE_SECRET_KEY=sk_live_...

# ── Targets ───────────────────────────────────────────────────────────────────
WEEKLY_REVENUE_TARGET=1000
OUTREACH_DAILY_LIMIT=15
LEADS_PER_RUN=20
