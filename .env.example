# Copy this file to .env and fill in values.
# Never commit .env to version control.

# Starting simulated portfolio balance
INITIAL_BALANCE=10000

# Exchange to use for live price data (no API key needed for public endpoints)
EXCHANGE=coinbase

# Symbol to trade (coinbase uses SOL/USD)
SYMBOL=SOL/USD

# ── Coinbase Advanced Trade Sandbox (required for --mode sandbox) ─────────────
#
# How to get sandbox credentials:
#   1. Register at https://public.sandbox.coinbase.com
#   2. Go to Settings → API → New API Key
#   3. Either download the JSON key file (option A) or copy key name + secret (option B)
#
# Option A — JSON key file (recommended, avoids multiline issues)
CB_SANDBOX_KEY_FILE=coinbase_sandbox_key.json

# Option B — inline credentials (comment out CB_SANDBOX_KEY_FILE if using this)
# CB_SANDBOX_API_KEY=organizations/YOUR_ORG_ID/apiKeys/YOUR_KEY_ID
# CB_SANDBOX_API_SECRET=-----BEGIN EC PRIVATE KEY-----\nYOUR_BASE64_KEY\n-----END EC PRIVATE KEY-----\n
